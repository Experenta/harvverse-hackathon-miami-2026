# Hoist transitive deps so legacy tools (hardhat plugins, etc.) can resolve them
shamefully-hoist=true

# Supply-chain protection: refuse packages published less than 7 days ago
minimum-release-age=10080

# Packages explicitly trusted to bypass minimum-release-age
minimum-release-age-exclude[]=@scaffold-ui/components
minimum-release-age-exclude[]=@scaffold-ui/debug-contracts
minimum-release-age-exclude[]=@scaffold-ui/hooks
minimum-release-age-exclude[]=burner-connector

# Use auto-install peers (matches yarn classic behavior expected by SE-2 deps)
auto-install-peers=true
